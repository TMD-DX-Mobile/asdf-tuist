#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=./lib/utils.bash
source "${plugin_dir}/lib/utils.bash"

mkdir -p "$ASDF_DOWNLOAD_PATH"

# This is not possible to download through the BNPP proxy,
# So we can git clone, and bundle in place… 🥲
sources_folder="$ASDF_DOWNLOAD_PATH/$TOOL_NAME-$ASDF_INSTALL_VERSION"
mkdir -p "$sources_folder"
git clone $GH_REPO --depth 1 --branch "$ASDF_INSTALL_VERSION" --single-branch "$sources_folder"
mise -C "$sources_folder" run spm:tuist:build Tuist-Workspace 2>&1 > /dev/null || mise -C "$sources_folder" run tuist:build Tuist-Workspace 2>&1 > /dev/null
cp "$sources_folder/.build/debug/tuist" "$ASDF_DOWNLOAD_PATH"
cp "$sources_folder/.build/debug/ProjectDescription.swiftmodule" "$ASDF_DOWNLOAD_PATH"
cp "$sources_folder/.build/debug/libProjectDescription.dylib" "$ASDF_DOWNLOAD_PATH"
cp -R "$sources_folder/.build/debug/libProjectDescription.dylib.dSYM" "$ASDF_DOWNLOAD_PATH"

# Remove the tar.gz file since we don't need to keep it
rm -rf "$sources_folder"
